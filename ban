-- 自动解锁保险箱
local function startAutoUnlockSafe()
    if AutoUnlockSafeConnection then return end
    SafeUnlocked = false
    AutoUnlockSafeConnection = task.spawn(function()
        while AutoUnlockSafeEnabled do
            local char = LocalPlayer.Character
            if not char then char = LocalPlayer.CharacterAdded:Wait() end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local lockpick = char:FindFirstChild("Lockpick")
            if not lockpick then task.wait(1); continue end
            local remote = lockpick:FindFirstChild("Remote")
            if not remote then task.wait(1); continue end
            local safe = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("BredMakurz") and Workspace.Map.BredMakurz:FindFirstChild("SmallSafe_C_3")
            if not safe then task.wait(5); continue end
            local dist = (hrp.Position - safe.Position).Magnitude
            if dist <= 5 and not SafeUnlocked then
                local s1, r1 = pcall(function() return remote:InvokeServer("D", safe, "s", 0.34505767977439417) end)
                local s2, r2 = pcall(function() return remote:InvokeServer("C") end)
                if s1 and s2 then SafeUnlocked = true; Windows:Notification("保险箱已自动解锁") end
            end
            task.wait(0.5)
        end
    end)
end
local function stopAutoUnlockSafe() if AutoUnlockSafeConnection then task.cancel(AutoUnlockSafeConnection); AutoUnlockSafeConnection = nil end end

