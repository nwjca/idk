-- 趴下姿势（原有）
local function applyProne(enable)
    local char = LocalPlayer.Character
    if not char then return end
    local torso = char:FindFirstChild("Torso")
    if not torso then return end
    local joints = {
        LeftShoulder = torso:FindFirstChild("Left Shoulder"),
        RightShoulder = torso:FindFirstChild("Right Shoulder"),
        LeftHip = torso:FindFirstChild("Left Hip"),
        RightHip = torso:FindFirstChild("Right Hip")
    }
    if enable then
        for n,j in pairs(joints) do if j and j:IsA("Motor6D") and not JointOriginalAngles[n] then JointOriginalAngles[n] = j.C0 end end
        if proneConnection then proneConnection:Disconnect() end
        proneConnection = RunService.RenderStepped:Connect(function()
            if not ProneEnabled then return end
            for n,j in pairs(joints) do
                if j and j:IsA("Motor6D") then
                    if n=="LeftShoulder" or n=="RightShoulder" then j.C0 = CFrame.Angles(math.rad(90),0,0)
                    elseif n=="LeftHip" or n=="RightHip" then j.C0 = CFrame.Angles(math.rad(-90),0,0) end
                end
            end
        end)
    else
        if proneConnection then proneConnection:Disconnect(); proneConnection = nil end
        for n,j in pairs(joints) do if j and j:IsA("Motor6D") and JointOriginalAngles[n] then j.C0 = JointOriginalAngles[n] end end
        JointOriginalAngles = {}
    end
end
LocalPlayer.CharacterAdded:Connect(function() if ProneEnabled then task.wait(0.5); applyProne(true) end end)

-- ccb动作（原有）
local function applyCcb(enable)
    if enable then
        local char = LocalPlayer.Character
        if not char then return end
        local torso = char:FindFirstChild("Torso")
        if not torso then return end
        local waist = torso:FindFirstChild("Waist")
        local rightShoulder = torso:FindFirstChild("Right Shoulder")
        if waist and waist:IsA("Motor6D") then CcbOriginalAngles["Waist"] = waist.C0 end
        if rightShoulder and rightShoulder:IsA("Motor6D") then CcbOriginalAngles["RightShoulder"] = rightShoulder.C0 end
        if ccbConnection then ccbConnection:Disconnect() end
        ccbConnection = RunService.RenderStepped:Connect(function()
            if not CcbEnabled then return end
            if waist and waist:IsA("Motor6D") and waist.Parent then waist.C0 = CFrame.Angles(math.rad(-45),0,0) end
            if rightShoulder and rightShoulder:IsA("Motor6D") and rightShoulder.Parent then rightShoulder.C0 = CFrame.Angles(math.rad(170),math.rad(10),0) end
        end)
    else
        if ccbConnection then ccbConnection:Disconnect(); ccbConnection = nil end
        local char = LocalPlayer.Character
        if char then
            local torso = char:FindFirstChild("Torso")
            if torso then
                local waist = torso:FindFirstChild("Waist")
                if waist and waist:IsA("Motor6D") and CcbOriginalAngles["Waist"] then waist.C0 = CcbOriginalAngles["Waist"] end
                local rightShoulder = torso:FindFirstChild("Right Shoulder")
                if rightShoulder and rightShoulder:IsA("Motor6D") and CcbOriginalAngles["RightShoulder"] then rightShoulder.C0 = CcbOriginalAngles["RightShoulder"] end
            end
        end
        CcbOriginalAngles = {}
    end
end
