-- 应用姿势的函数
local function applyPose(index)
    if currentPoseIndex == index then return end -- 相同姿势不重复应用
    
    -- 停止之前的姿势连接
    for _, conn in ipairs(poseConnections) do
        pcall(function() conn:Disconnect() end)
    end
    poseConnections = {}
    
    -- 恢复原始角度（如果存在）
    local char = LocalPlayer.Character
    if char then
        local torso = char:FindFirstChild("Torso")
        if torso then
            for name, joint in pairs(poseJoints) do
                if joint and joint:IsA("Motor6D") and poseOriginalAngles[name] then
                    joint.C0 = poseOriginalAngles[name]
                end
            end
        end
    end
    
    poseJoints = {}
    poseOriginalAngles = {}
    
    if index == 0 then
        currentPoseIndex = 0
        return
    end
    
    -- 获取当前角色的关节
    char = LocalPlayer.Character
    if not char then return end
    local torso = char:FindFirstChild("Torso")
    if not torso then return end
    
    local joints = {
        LeftShoulder = torso:FindFirstChild("Left Shoulder"),
        RightShoulder = torso:FindFirstChild("Right Shoulder"),
        LeftHip = torso:FindFirstChild("Left Hip"),
        RightHip = torso:FindFirstChild("Right Hip"),
        Neck = char:FindFirstChild("Head") and char.Head:FindFirstChild("Neck") or torso:FindFirstChild("Neck"),
        Waist = torso:FindFirstChild("Waist")
    }
    
    for name, joint in pairs(joints) do
        if joint and joint:IsA("Motor6D") then
            poseJoints[name] = joint
            poseOriginalAngles[name] = joint.C0
        end
    end
    
    -- 创建新的连接
    local conn = RunService.RenderStepped:Connect(function()
        if not LocalPlayer.Character then return end
        local char = LocalPlayer.Character
        local torso = char:FindFirstChild("Torso")
        if not torso then return end
        
        for name, joint in pairs(poseJoints) do
            if joint and joint.Parent then
                local angle = Poses[index][name]
                if angle then
                    joint.C0 = angle
                end
            end
        end
    end)
    
    table.insert(poseConnections, conn)
    currentPoseIndex = index
end

